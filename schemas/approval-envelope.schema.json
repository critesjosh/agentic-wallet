{
  "$defs": {
    "AccessListEntry": {
      "additionalProperties": false,
      "properties": {
        "address": {
          "pattern": "^0x[0-9a-fA-F]{40}$",
          "title": "Address",
          "type": "string"
        },
        "storage_keys": {
          "items": {
            "pattern": "^0x[0-9a-fA-F]{64}$",
            "type": "string"
          },
          "title": "Storage Keys",
          "type": "array"
        }
      },
      "required": [
        "address"
      ],
      "title": "AccessListEntry",
      "type": "object"
    },
    "Amount": {
      "additionalProperties": false,
      "description": "A token amount as integer base units. Never a float.\n\n``base_units`` is the on-chain integer (wei-like) as a decimal string;\n``decimals`` records the token scale for display only.",
      "properties": {
        "base_units": {
          "title": "Base Units",
          "type": "string"
        },
        "decimals": {
          "title": "Decimals",
          "type": "integer"
        }
      },
      "required": [
        "base_units",
        "decimals"
      ],
      "title": "Amount",
      "type": "object"
    },
    "AssetDelta": {
      "additionalProperties": false,
      "properties": {
        "asset_id": {
          "pattern": "^[a-z0-9]+:[a-z0-9\\-]+$",
          "title": "Asset Id",
          "type": "string"
        },
        "amount": {
          "$ref": "#/$defs/Amount"
        }
      },
      "required": [
        "asset_id",
        "amount"
      ],
      "title": "AssetDelta",
      "type": "object"
    },
    "BalanceChange": {
      "additionalProperties": false,
      "properties": {
        "asset_id": {
          "pattern": "^[a-z0-9]+:[a-z0-9\\-]+$",
          "title": "Asset Id",
          "type": "string"
        },
        "delta_base_units": {
          "title": "Delta Base Units",
          "type": "string"
        }
      },
      "required": [
        "asset_id",
        "delta_base_units"
      ],
      "title": "BalanceChange",
      "type": "object"
    },
    "Eip1559Transaction": {
      "additionalProperties": false,
      "description": "The real transaction preimage fields, not a display-only summary.",
      "properties": {
        "transaction_type": {
          "const": 2,
          "default": 2,
          "title": "Transaction Type",
          "type": "integer"
        },
        "chain_id": {
          "title": "Chain Id",
          "type": "integer"
        },
        "nonce": {
          "pattern": "^(0|[1-9]\\d*)$",
          "title": "Nonce",
          "type": "string"
        },
        "max_priority_fee_per_gas": {
          "pattern": "^(0|[1-9]\\d*)$",
          "title": "Max Priority Fee Per Gas",
          "type": "string"
        },
        "max_fee_per_gas": {
          "pattern": "^(0|[1-9]\\d*)$",
          "title": "Max Fee Per Gas",
          "type": "string"
        },
        "gas_limit": {
          "pattern": "^(0|[1-9]\\d*)$",
          "title": "Gas Limit",
          "type": "string"
        },
        "from_address": {
          "pattern": "^0x[0-9a-fA-F]{40}$",
          "title": "From Address",
          "type": "string"
        },
        "to_address": {
          "pattern": "^0x[0-9a-fA-F]{40}$",
          "title": "To Address",
          "type": "string"
        },
        "value": {
          "pattern": "^(0|[1-9]\\d*)$",
          "title": "Value",
          "type": "string"
        },
        "data": {
          "default": "0x",
          "pattern": "^0x[0-9a-fA-F]*$",
          "title": "Data",
          "type": "string"
        },
        "access_list": {
          "items": {
            "$ref": "#/$defs/AccessListEntry"
          },
          "title": "Access List",
          "type": "array"
        }
      },
      "required": [
        "chain_id",
        "nonce",
        "max_priority_fee_per_gas",
        "max_fee_per_gas",
        "gas_limit",
        "from_address",
        "to_address",
        "value"
      ],
      "title": "Eip1559Transaction",
      "type": "object"
    },
    "PolicyResult": {
      "additionalProperties": false,
      "properties": {
        "allowed": {
          "title": "Allowed",
          "type": "boolean"
        },
        "violations": {
          "items": {
            "type": "string"
          },
          "title": "Violations",
          "type": "array"
        },
        "requires_elevated_confirmation": {
          "default": false,
          "title": "Requires Elevated Confirmation",
          "type": "boolean"
        }
      },
      "required": [
        "allowed"
      ],
      "title": "PolicyResult",
      "type": "object"
    },
    "SimulationResult": {
      "additionalProperties": false,
      "properties": {
        "plan_id": {
          "title": "Plan Id",
          "type": "string"
        },
        "success": {
          "title": "Success",
          "type": "boolean"
        },
        "block": {
          "title": "Block",
          "type": "integer"
        },
        "gas_used": {
          "title": "Gas Used",
          "type": "integer"
        },
        "balance_changes": {
          "items": {
            "$ref": "#/$defs/BalanceChange"
          },
          "title": "Balance Changes",
          "type": "array"
        },
        "unexpected_transfers": {
          "items": {
            "$ref": "#/$defs/BalanceChange"
          },
          "title": "Unexpected Transfers",
          "type": "array"
        },
        "mismatch": {
          "default": false,
          "title": "Mismatch",
          "type": "boolean"
        },
        "logs_summary": {
          "default": "",
          "title": "Logs Summary",
          "type": "string"
        }
      },
      "required": [
        "plan_id",
        "success",
        "block",
        "gas_used"
      ],
      "title": "SimulationResult",
      "type": "object"
    },
    "TransactionPlan": {
      "additionalProperties": false,
      "properties": {
        "plan_id": {
          "title": "Plan Id",
          "type": "string"
        },
        "chain_id": {
          "title": "Chain Id",
          "type": "integer"
        },
        "kind": {
          "enum": [
            "transfer",
            "swap",
            "approval"
          ],
          "title": "Kind",
          "type": "string"
        },
        "from_address": {
          "pattern": "^0x[0-9a-fA-F]{40}$",
          "title": "From Address",
          "type": "string"
        },
        "to_address": {
          "pattern": "^0x[0-9a-fA-F]{40}$",
          "title": "To Address",
          "type": "string"
        },
        "recipient_address": {
          "anyOf": [
            {
              "pattern": "^0x[0-9a-fA-F]{40}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Recipient Address"
        },
        "asset_id": {
          "pattern": "^[a-z0-9]+:[a-z0-9\\-]+$",
          "title": "Asset Id",
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/Amount"
        },
        "calldata": {
          "default": "0x",
          "pattern": "^0x[0-9a-fA-F]*$",
          "title": "Calldata",
          "type": "string"
        },
        "expected_incoming": {
          "items": {
            "$ref": "#/$defs/AssetDelta"
          },
          "title": "Expected Incoming",
          "type": "array"
        },
        "expected_outgoing": {
          "items": {
            "$ref": "#/$defs/AssetDelta"
          },
          "title": "Expected Outgoing",
          "type": "array"
        },
        "gas_reserve": {
          "anyOf": [
            {
              "$ref": "#/$defs/Amount"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "max_slippage_bps": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Slippage Bps"
        },
        "quote_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Quote Id"
        },
        "quote_expires_at": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Quote Expires At"
        }
      },
      "required": [
        "plan_id",
        "chain_id",
        "kind",
        "from_address",
        "to_address",
        "asset_id",
        "value"
      ],
      "title": "TransactionPlan",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "chain_id": {
      "title": "Chain Id",
      "type": "integer"
    },
    "plan": {
      "$ref": "#/$defs/TransactionPlan"
    },
    "simulation": {
      "$ref": "#/$defs/SimulationResult"
    },
    "policy": {
      "$ref": "#/$defs/PolicyResult"
    },
    "expires_at": {
      "title": "Expires At",
      "type": "integer"
    },
    "state_anchor": {
      "title": "State Anchor",
      "type": "string"
    },
    "nonce": {
      "title": "Nonce",
      "type": "integer"
    },
    "signing_transaction": {
      "anyOf": [
        {
          "$ref": "#/$defs/Eip1559Transaction"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "chain_id",
    "plan",
    "simulation",
    "policy",
    "expires_at",
    "state_anchor",
    "nonce"
  ],
  "title": "ApprovalEnvelope",
  "type": "object"
}
