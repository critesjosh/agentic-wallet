{
  "$defs": {
    "Amount": {
      "additionalProperties": false,
      "description": "A token amount as integer base units. Never a float.\n\n``base_units`` is the on-chain integer (wei-like) as a decimal string;\n``decimals`` records the token scale for display only.",
      "properties": {
        "base_units": {
          "title": "Base Units",
          "type": "string"
        },
        "decimals": {
          "title": "Decimals",
          "type": "integer"
        }
      },
      "required": [
        "base_units",
        "decimals"
      ],
      "title": "Amount",
      "type": "object"
    },
    "AssetDelta": {
      "additionalProperties": false,
      "properties": {
        "asset_id": {
          "pattern": "^[a-z0-9]+:[a-z0-9\\-]+$",
          "title": "Asset Id",
          "type": "string"
        },
        "amount": {
          "$ref": "#/$defs/Amount"
        }
      },
      "required": [
        "asset_id",
        "amount"
      ],
      "title": "AssetDelta",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "plan_id": {
      "title": "Plan Id",
      "type": "string"
    },
    "chain_id": {
      "title": "Chain Id",
      "type": "integer"
    },
    "kind": {
      "enum": [
        "transfer",
        "swap",
        "approval"
      ],
      "title": "Kind",
      "type": "string"
    },
    "from_address": {
      "pattern": "^0x[0-9a-fA-F]{40}$",
      "title": "From Address",
      "type": "string"
    },
    "to_address": {
      "pattern": "^0x[0-9a-fA-F]{40}$",
      "title": "To Address",
      "type": "string"
    },
    "recipient_address": {
      "anyOf": [
        {
          "pattern": "^0x[0-9a-fA-F]{40}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Recipient Address"
    },
    "asset_id": {
      "pattern": "^[a-z0-9]+:[a-z0-9\\-]+$",
      "title": "Asset Id",
      "type": "string"
    },
    "value": {
      "$ref": "#/$defs/Amount"
    },
    "calldata": {
      "default": "0x",
      "pattern": "^0x[0-9a-fA-F]*$",
      "title": "Calldata",
      "type": "string"
    },
    "expected_incoming": {
      "items": {
        "$ref": "#/$defs/AssetDelta"
      },
      "title": "Expected Incoming",
      "type": "array"
    },
    "expected_outgoing": {
      "items": {
        "$ref": "#/$defs/AssetDelta"
      },
      "title": "Expected Outgoing",
      "type": "array"
    },
    "gas_reserve": {
      "anyOf": [
        {
          "$ref": "#/$defs/Amount"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "max_slippage_bps": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Max Slippage Bps"
    },
    "quote_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Quote Id"
    },
    "quote_expires_at": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Quote Expires At"
    }
  },
  "required": [
    "plan_id",
    "chain_id",
    "kind",
    "from_address",
    "to_address",
    "asset_id",
    "value"
  ],
  "title": "TransactionPlan",
  "type": "object"
}
