{
  "additionalProperties": false,
  "properties": {
    "recipient_id": {
      "pattern": "^recipient:[a-z0-9-]+$",
      "title": "Recipient Id",
      "type": "string"
    },
    "address": {
      "pattern": "^0x[0-9a-fA-F]{40}$",
      "title": "Address",
      "type": "string"
    },
    "provenance": {
      "enum": [
        "current-user-input",
        "verified-contact"
      ],
      "title": "Provenance",
      "type": "string"
    }
  },
  "required": [
    "recipient_id",
    "address",
    "provenance"
  ],
  "title": "TrustedRecipientCandidate",
  "type": "object"
}
