{
  "additionalProperties": false,
  "description": "Safe submission metadata; raw signed bytes never cross the signer boundary.",
  "properties": {
    "status": {
      "enum": [
        "SUBMITTED",
        "UNKNOWN"
      ],
      "title": "Status",
      "type": "string"
    },
    "from_address": {
      "pattern": "^0x[0-9a-fA-F]{40}$",
      "title": "From Address",
      "type": "string"
    },
    "envelope_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Envelope Digest",
      "type": "string"
    },
    "transaction_signing_hash": {
      "pattern": "^0x[0-9a-fA-F]{64}$",
      "title": "Transaction Signing Hash",
      "type": "string"
    },
    "transaction_hash": {
      "pattern": "^0x[0-9a-fA-F]{64}$",
      "title": "Transaction Hash",
      "type": "string"
    }
  },
  "required": [
    "status",
    "from_address",
    "envelope_digest",
    "transaction_signing_hash",
    "transaction_hash"
  ],
  "title": "SignedTransactionResult",
  "type": "object"
}
