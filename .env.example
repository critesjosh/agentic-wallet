# Default local web POC. Never put real secrets in this example file.
AGENTIC_WALLET_INFERENCE_PROVIDER=ollama
AGENTIC_WALLET_MODEL_ID=gemma4:e2b
AGENTIC_WALLET_INFERENCE_BASE_URL=http://127.0.0.1:11434
AGENTIC_WALLET_DEBUG_TRANSCRIPTS=0
AGENTIC_WALLET_WEB_HOST=127.0.0.1
AGENTIC_WALLET_WEB_PORT=8000

# Remote OpenRouter mode requires per-message UI consent.
# OPENROUTER_API_KEY=
AGENTIC_WALLET_OPENROUTER_DATA_COLLECTION=deny
AGENTIC_WALLET_OPENROUTER_ZDR=false

# Optional local-only Phase 8 transaction POC. Disabled by default.
# Provision the private key with scripts/provision_signer_key.py; never put it
# in this file. The HMAC value must be URL-safe base64 decoding to >=32 bytes.
# AGENTIC_WALLET_TRANSACTION_ENABLED=true
# AGENTIC_WALLET_SIGNER_RPC_URL=https://your-base-rpc.example
# AGENTIC_WALLET_APPROVAL_HMAC_KEY=
# Signing chain: 8453 (Base) or 84532 (Base Sepolia). Defaults to 8453, so set
# it explicitly to 84532 to keep the proof of concept on testnet funds.
# AGENTIC_WALLET_SIGNER_CHAIN_ID=84532
